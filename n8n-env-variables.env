# ─────────────────────────────────────────────────────────
#  Roblox Content Machine – n8n Environment Variables
# ─────────────────────────────────────────────────────────
#  Set these in: n8n Settings → Variables (or .env for self-hosted)
#
#  Both workflows reference these via $env.VARIABLE_NAME
#  so you only configure them once across all workflows.
# ─────────────────────────────────────────────────────────

# ── Google Sheets ──
GOOGLE_SHEET_ID=your_spreadsheet_id_here
# Where to find it: open the Google Sheet → URL is docs.google.com/spreadsheets/d/{THIS_PART}/edit

# ── Google Drive Folders ──
READY_TO_POST_FOLDER_ID=your_folder_id_here
ARCHIVE_FOLDER_ID=your_folder_id_here
# Where to find it: open the folder in Drive → URL is drive.google.com/drive/folders/{THIS_PART}

# ── YouTube ──
YT_CHANNEL_ID=your_youtube_channel_id
# Where to find: YouTube Studio → Settings → Channel → Advanced → Channel ID

# ── Instagram ──
IG_USER_ID=your_ig_business_account_id
# How to find: Graph API Explorer → GET /me/accounts → find your Page →
#   GET /{page-id}?fields=instagram_business_account → the "id" value

# ── Facebook ──
FB_PAGE_ID=your_fb_page_id
# How to find: Facebook Page → About → Page ID (at bottom),
#   or Graph API Explorer → GET /me/accounts → "id" field

# ── Telegram ──
TELEGRAM_CHAT_ID=your_chat_id
# How to find: open Telegram → message @userinfobot → it replies with your ID

# ── Timezone (3 PM EDT = 19:00 UTC) ──
# During US Daylight Saving (Mar–Nov):  EDT = UTC-4  → target = 19:00 UTC
# During US Standard  (Nov–Mar):        EST = UTC-5  → target = 20:00 UTC
# The Publisher workflow hardcodes 19:00 UTC (EDT).
# To switch to EST, change target.setUTCHours(19,...) to (20,...) in the
# "Calculate 3 PM EDT Epoch" node.
PUBLISH_HOUR_UTC=19
